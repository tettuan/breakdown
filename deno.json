{
  "imports": {
    "@/": "./src/",
    "@std/fs": "jsr:@std/fs@^0.218.2",
    "@std/path": "jsr:@std/path@^0.218.2",
    "@std/io": "jsr:@std/io@^0.218.2",
    "@std/cli": "jsr:@std/cli@^0.218.2",
    "@std/console": "jsr:@std/console@^0.218.2",
    "@cliffy/": "https://deno.land/x/cliffy@v1.0.0-rc.3/"
  },
  "tasks": {
    "dev": "deno run --watch main.ts",
    "test": "deno test -A"
  },
  "fmt": {
    "files": {
      "include": ["src/", "tests/"]
    },
    "options": {
      "useTabs": false,
      "lineWidth": 80,
      "indentWidth": 2,
      "singleQuote": true,
      "proseWrap": "always"
    }
  },
  "lint": {
    "files": {
      "include": ["src/"]
    },
    "rules": {
      "tags": ["recommended"]
    }
  },
  "compilerOptions": {
    "lib": ["deno.window", "deno.ns"],
    "strict": true
  }
} 