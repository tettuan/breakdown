{
  "name": "@tettuan/breakdown",
  "version": "1.8.8",
  "exports": {
    ".": "./mod.ts"
  },
  "bin": {
    "breakdown": "./cli/breakdown.ts"
  },
  "imports": {
    "$std/": "jsr:@std/",
    "$deps/": "./deps/",
    "$lib/": "./lib/",
    "$test/": "./tests/",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fs": "jsr:@std/fs@^1.0.23",
    "@std/cli": "jsr:@std/cli@^1.0.28",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "@tettuan/breakdown": "jsr:@tettuan/breakdown@^1.8.2",
    "@tettuan/breakdownconfig": "jsr:@tettuan/breakdownconfig@^1.2.5",
    "@tettuan/breakdownparams": "jsr:@tettuan/breakdownparams@^1.2.3",
    "@tettuan/breakdownprompt": "jsr:@tettuan/breakdownprompt@^1.2.8",
    "@tettuan/breakdownlogger": "jsr:@tettuan/breakdownlogger@^1.1.3"
  },
  "publish": {
    "include": [
      "README.md",
      "LICENSE",
      "mod.ts",
      "lib/",
      "cli/",
      "CHANGELOG.md"
    ],
    "exclude": [
      "**/日本語.*",
      "**/*.ja.*",
      "examples/",
      "tests/",
      "*test.ts",
      "draft/",
      "CLAUDE.md"
    ]
  },
  "tasks": {
    "ci": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net jsr:@aidevtool/ci",
    "ci:dirty": "deno run --allow-read --allow-write --allow-run --allow-env --allow-net jsr:@aidevtool/ci --allow-dirty",
    "test": "deno test --allow-env --allow-write --allow-read --allow-run",
    "test:unit": "deno test lib/ --allow-env --allow-write --allow-read --allow-run",
    "test:integration": "deno test tests/ --allow-env --allow-write --allow-read --allow-run",
    "test:e2e": "deno test tests/4_cross_domain/e2e/ --allow-env --allow-write --allow-read --allow-run"
  },
  "fmt": {
    "indentWidth": 2,
    "singleQuote": false,
    "lineWidth": 100,
    "exclude": [
      "tmp/",
      "examples/",
      "**/*.md",
      "**/*.markdown"
    ]
  },
  "lint": {
    "include": [
      "lib/",
      "tests/",
      "cli/"
    ],
    "exclude": [
      "tmp/",
      "tests/fixtures/",
      "**/*.ja.*",
      "**/日本語.*"
    ],
    "rules": {
      "tags": [
        "recommended"
      ],
      "include": [
        "no-eval",
        "no-sync-fn-in-async-fn",
        "prefer-ascii",
        "single-var-declarator",
        "verbatim-module-syntax"
      ]
    }
  },
  "compilerOptions": {
    "strict": true,
    "lib": [
      "deno.window"
    ]
  },
  "test": {
    "exclude": [
      "tmp/",
      "examples/"
    ]
  },
  "exclude": [
    "tmp/",
    "examples/tmp/"
  ]
}
